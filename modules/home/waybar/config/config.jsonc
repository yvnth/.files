{
  "layer": "top",
  "position": "top",
  "exclusive": true,
  "modules-left": [
    "clock#time",
    "clock#date",
    "memory",
    "cpu"
  ],
  "modules-center": [
    "mango/workspaces",
    "mango/layout"
  ],
  "modules-right": [
    "tray",
    "custom/notifications",
    "battery",
    "pulseaudio",
    "backlight",
    "network"
  ],
  "mango/workspaces": {
    "format": "{icon}",
    "hide-empty": true,
    "on-click": "activate"
  },
  "mango/layout": {
    "format": "{}",
    "format-CT": "center_tile",
    "format-K": "deck",
    "format-DW": "dwindle",
    "format-F": "fair",
    "format-G": "grid",
    "format-M": "monocle",
    "format-RT": "right_tile",
    "format-S": "scroller",
    "format-T": "tile",
    "format-VK": "vertical_deck",
    "format-VF": "vertical_fair",
    "format-VG": "vertical_grid",
    "format-VS": "vertical_scroller",
    "format-VT": "vertical_tile"
  },
  "network": {
    "interval": 5,
    "format-wifi": " {essid}",
    "format-ethernet": " {ipaddr}",
    "format-disconnected": ""
  },
  "memory": {
    "interval": 2,
    "format": " {percentage:2}%"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "󰃠 {percent}%"
  },
  "cpu": {
    "interval": 2,
    "format": "󰾆 {usage:2}%"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "",
    "format-icons": {
      "default": [
        "",
        "",
        ""
      ]
    },
    "on-click": "pavucontrol"
  },
  "battery": {
    "interval": 3,
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 10
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰂄 {capacity}%",
    "format-full": "󰁹 {capacity}%",
    "format-icons": [
      "󰁺",
      "󰁻",
      "󰁼",
      "󰁽",
      "󰁾",
      "󰁿",
      "󰂀",
      "󰂁",
      "󰂂",
      "󰁹"
    ],
    "tooltip-format": "{capacity}%"
  },
  "clock#date": {
    "interval": 60,
    "format": "{:%d/%m/%Y}",
    "tooltip": false
  },
  "clock#time": {
    "interval": 1,
    "format": "{:%H:%M:%S}",
    "tooltip": false
  },
  "custom/notifications": {
    "format": "󰂚",
    "on-click": "swaync-client -t"
  },
  "tray": {
    "spacing": 4
  }
}